# ============================================================
# CodeArena Backend — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit the real .env file
# ============================================================

# Server port (Render sets this automatically)
PORT=5000

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/codearena?retryWrites=true&w=majority

# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Your deployed frontend URL (for CORS) — set this after frontend deployment
# Example: https://codearena-elite.vercel.app
FRONTEND_URL=https://your-frontend-url.vercel.app
