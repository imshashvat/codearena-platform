# ============================================================
# CodeArena Frontend — Environment Variables
# Copy this file to .env.local for local dev (optional)
# On Vercel: set VITE_API_URL in the Environment Variables section
# ============================================================

# Your deployed Railway backend URL — MUST end with /api
# Example: https://codearena-backend-production.up.railway.app/api
VITE_API_URL=https://your-railway-backend-url.up.railway.app/api
